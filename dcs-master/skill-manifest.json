{
  "name": "dcs-master",
  "display_name": "DCS Master 助手",
  "version": "1.0.3",
  "source": {
    "repo": "Kidd-Ye/dcs-master",
    "ref": "main",
    "path": "dcs-master",
    "manifest_path": "dcs-master/skill-manifest.json",
    "homepage": "https://github.com/Kidd-Ye/dcs-master"
  },
  "update": {
    "check_on_load": true,
    "install_command": "python3 -c \"import pathlib,tempfile,urllib.request,subprocess,sys;root=pathlib.Path(tempfile.gettempdir())/'dcs-master-bootstrap';root.mkdir(exist_ok=True);script=root/'upgrade-from-github.py';script.write_bytes(urllib.request.urlopen('https://raw.githubusercontent.com/Kidd-Ye/dcs-master/main/dcs-master/scripts/upgrade-from-github.py', timeout=20).read());subprocess.run([sys.executable,str(script),'codex','--to',str(pathlib.Path.home()/'.codex/skills')], check=True)\"",
    "notes_url": "https://github.com/Kidd-Ye/dcs-master/releases"
  }
}
